# Copy to rclone.conf and fill in your credentials.
# The remote must be named "destination" (or set RCLONE_REMOTE env var to match).

# --- FTP ---
[destination]
type = ftp
host = ftp.yourhost.com
user = your-ftp-user
pass = your-rclone-obscured-password   # run: rclone obscure yourpassword

# --- S3 (future / alternative) ---
# [destination]
# type = s3
# provider = AWS
# access_key_id = AKIAXXXXXXXXXXXXXXXX
# secret_access_key = xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# region = eu-central-1

# --- Backblaze B2 (alternative) ---
# [destination]
# type = b2
# account = your-account-id
# key = your-application-key
